---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/site';
---

<BaseLayout title="Contacte" description="Contacta amb el Club Handbol Sueca">
  <section class="bg-primary py-20">
    <div class="container-custom text-center">
      <h1 class="font-heading font-extrabold text-3xl sm:text-4xl md:text-5xl text-white" data-aos="fade-up">
        Contacte
      </h1>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Formulario -->
        <div data-aos="fade-right">
          <h2 class="font-heading font-bold text-2xl text-dark mb-6">Envia'ns un missatge</h2>
          <form action="https://formspree.io/f/XXXXXXXX" method="POST" class="space-y-4">
            <!-- TODO: sustituir XXXXXXXX por el ID real de Formspree -->
            <div>
              <label for="name" class="block text-sm font-medium text-dark mb-1">Nom</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full border border-dark/20 rounded-sm px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors"
                placeholder="El teu nom"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-dark mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full border border-dark/20 rounded-sm px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors"
                placeholder="El teu email"
              />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-dark mb-1">Assumpte</label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                class="w-full border border-dark/20 rounded-sm px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors"
                placeholder="Assumpte del missatge"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-dark mb-1">Missatge</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full border border-dark/20 rounded-sm px-4 py-3 text-sm focus:outline-none focus:border-primary transition-colors resize-none"
                placeholder="Escriu el teu missatge..."
              ></textarea>
            </div>
            <button type="submit" class="btn-primary w-full text-center">
              Enviar missatge
            </button>
          </form>
        </div>

        <!-- Info contacto -->
        <div data-aos="fade-left">
          <h2 class="font-heading font-bold text-2xl text-dark mb-6">Informació de contacte</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D10A11" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-dark">Adreça</h3>
                <p class="text-dark/60 text-sm mt-1">{siteConfig.contact.address}<br>{siteConfig.contact.city}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D10A11" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-dark">Telèfon</h3>
                <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, '')}`} class="text-dark/60 text-sm mt-1 hover:text-primary transition-colors">
                  {siteConfig.contact.phone}
                </a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D10A11" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-dark">Email</h3>
                <a href={`mailto:${siteConfig.contact.email}`} class="text-dark/60 text-sm mt-1 hover:text-primary transition-colors">
                  {siteConfig.contact.email}
                </a>
              </div>
            </div>
          </div>

          <!-- Mapa placeholder -->
          <div class="mt-8 bg-gray-soft rounded-sm overflow-hidden h-64 flex items-center justify-center">
            <p class="text-dark/40 text-sm">
              <!-- TODO: insertar iframe de Google Maps -->
              Mapa de Sueca - Ronda del País Valencià, 23
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
