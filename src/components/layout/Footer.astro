---
import { siteConfig } from '../../data/site';
import NewsletterForm from './NewsletterForm.astro';
import { withBase } from '../../utils/url';
---

<footer class="bg-dark text-white">
  <div class="container-custom section-padding">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10 lg:gap-12">
      <!-- Columna 1: Logo + descripción + newsletter -->
      <div class="lg:col-span-1">
        <a href={withBase('/')} class="flex items-center gap-3 mb-4">
          <img
            src={withBase(siteConfig.logo)}
            alt={`Logo ${siteConfig.name}`}
            width="64"
            height="64"
            class="w-14 h-14 object-contain"
            onerror="this.style.display='none'"
          />
          <span class="font-heading font-bold text-xl">{siteConfig.shortName}</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-6">
          {siteConfig.name} - Formant esportistes i persones des de {siteConfig.founded}.
          Vine a gaudir del handbol amb nosaltres!
        </p>
        <NewsletterForm />
      </div>

      <!-- Columna 2: Club -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-6 relative">
          Club
          <span class="absolute bottom-0 left-0 w-8 h-0.5 bg-primary -mb-2"></span>
        </h3>
        <ul class="space-y-3 mt-4">
          <li><a href={withBase('/club/historia')} class="text-white/60 hover:text-primary-light transition-colors text-sm">Història</a></li>
          <li><a href={withBase('/club/qui-som')} class="text-white/60 hover:text-primary-light transition-colors text-sm">Qui som</a></li>
          <li><a href={withBase('/club/directiva')} class="text-white/60 hover:text-primary-light transition-colors text-sm">Directiva</a></li>
          <li><a href={withBase('/club/contacte')} class="text-white/60 hover:text-primary-light transition-colors text-sm">Contacte</a></li>
        </ul>
      </div>

      <!-- Columna 3: Enllaços -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-6 relative">
          Enllaços
          <span class="absolute bottom-0 left-0 w-8 h-0.5 bg-primary -mb-2"></span>
        </h3>
        <ul class="space-y-3 mt-4">
          <li><a href={withBase('/equips')} class="text-white/60 hover:text-primary-light transition-colors text-sm">Equips</a></li>
          <li><a href={withBase('/events')} class="text-white/60 hover:text-primary-light transition-colors text-sm">Events</a></li>
          <li><a href={withBase('/informacio')} class="text-white/60 hover:text-primary-light transition-colors text-sm">Informació</a></li>
          <li><a href={withBase('/colaboradors')} class="text-white/60 hover:text-primary-light transition-colors text-sm">Col·laboradors</a></li>
        </ul>
      </div>

      <!-- Columna 4: Contacte -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-6 relative">
          Contacte
          <span class="absolute bottom-0 left-0 w-8 h-0.5 bg-primary -mb-2"></span>
        </h3>
        <ul class="space-y-4 mt-4">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-white/60 text-sm">{siteConfig.contact.address}<br>{siteConfig.contact.city}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, '')}`} class="text-white/60 hover:text-primary-light transition-colors text-sm">
              {siteConfig.contact.phone}
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <a href={`mailto:${siteConfig.contact.email}`} class="text-white/60 hover:text-primary-light transition-colors text-sm">
              {siteConfig.contact.email}
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-white/10">
    <div class="container-custom py-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/40 text-sm">
        &copy; {new Date().getFullYear()} {siteConfig.name}. Tots els drets reservats.
      </p>
      <div class="flex items-center gap-4">
        <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-white/40 hover:text-primary-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-white/40 hover:text-primary-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
