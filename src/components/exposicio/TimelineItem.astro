---
interface Props {
  year: string;
  label: string;
  text: string;
  image?: string;
  imageAlt?: string;
}
const { year, label, text, image, imageAlt = '' } = Astro.props;
---

<div class="timeline-item reveal">
  <div class="timeline-node">
    <div class="node-dot"></div>
  </div>
  <div class="timeline-content">
    <div class="timeline-text-col">
      <div class="timeline-year exp-display">{year}</div>
      <div class="timeline-label exp-accent">{label}</div>
      <p class="timeline-text exp-body">{text}</p>
    </div>
    {image && (
      <div class="timeline-img-col">
        <img src={image} alt={imageAlt} loading="lazy" class="timeline-img" />
      </div>
    )}
  </div>
</div>

<style>
  .timeline-item {
    display: flex;
    gap: 2rem;
    padding-bottom: 3rem;
    position: relative;
  }

  .timeline-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .node-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--chalk-blue);
    box-shadow:
      0 0 0 4px rgba(74, 184, 224, 0.2),
      0 0 12px 4px rgba(74, 184, 224, 0.4);
    flex-shrink: 0;
    margin-top: 0.35rem;
  }

  .timeline-content {
    display: flex;
    gap: 2rem;
    flex: 1;
    align-items: flex-start;
  }

  .timeline-text-col {
    flex: 1;
  }

  .timeline-year {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1;
    color: var(--chalk-red);
    margin-bottom: 0.25rem;
  }

  .timeline-label {
    font-family: 'Caveat', cursive;
    font-size: 1.25rem;
    color: var(--chalk-blue-bright);
    margin-bottom: 0.75rem;
  }

  .timeline-text {
    font-family: 'Oswald', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--chalk-dim);
  }

  .timeline-img-col {
    flex-shrink: 0;
    width: 180px;
  }

  .timeline-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid rgba(74, 184, 224, 0.2);
    filter: sepia(0.1) brightness(0.9);
    transition: filter 0.3s;
  }

  .timeline-item:hover .timeline-img {
    filter: sepia(0) brightness(1);
  }

  @media (max-width: 768px) {
    .timeline-content {
      flex-direction: column;
    }

    .timeline-img-col {
      width: 100%;
    }

    .timeline-img {
      aspect-ratio: 16 / 9;
    }
  }
</style>
