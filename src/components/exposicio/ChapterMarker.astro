---
interface Props {
  numero: string;
  titol: string;
}
const { numero, titol } = Astro.props;
---

<div class="chapter-marker">
  <span class="marker-text">Capítol {numero} · {titol}</span>
  <div class="marker-line"></div>
</div>

<style>
  .chapter-marker {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .marker-text {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--chalk-blue);
    white-space: nowrap;
  }

  .marker-line {
    flex: 1;
    height: 1px;
    background: var(--chalk-blue);
    box-shadow: 0 0 6px 1px var(--chalk-blue);
    filter: blur(0.3px);
    opacity: 0.6;
  }
</style>
