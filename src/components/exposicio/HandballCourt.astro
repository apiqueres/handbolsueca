---
// Handball court SVG — no props, self-contained
---

<div class="court-wrapper">
  <svg
    viewBox="0 0 800 400"
    xmlns="http://www.w3.org/2000/svg"
    class="court-svg"
    role="img"
    aria-label="Diagrama d'una pista de handbol reglamentària de 40m × 20m"
  >
    <!-- Background floor -->
    <rect width="800" height="400" fill="#c8651e" />

    <!-- Playing area -->
    <rect x="20" y="20" width="760" height="360" fill="#3a9bc7" />

    <!-- Outer boundary lines -->
    <rect x="20" y="20" width="760" height="360" fill="none" stroke="white" stroke-width="2.5" />

    <!-- Center line -->
    <line x1="400" y1="20" x2="400" y2="380" stroke="white" stroke-width="2.5" />

    <!-- Center circle -->
    <circle cx="400" cy="200" r="45" fill="none" stroke="white" stroke-width="2" />
    <circle cx="400" cy="200" r="3" fill="white" />

    <!-- LEFT SIDE: 6m area (D-zone, solid) -->
    <path
      d="M 20 110 L 20 290 Q 20 290 110 290 A 200 200 0 0 0 110 110 Q 20 110 20 110 Z"
      fill="rgba(0,0,0,0.2)"
      stroke="white"
      stroke-width="2.5"
    />
    <!-- Cleaner 6m arc left -->
    <path
      d="M 20 105 A 195 195 0 0 1 20 295"
      fill="none"
      stroke="none"
    />
    <path
      d="M 115 200 m -195 0 a 195 195 0 0 1 195 -95 L 20 105 L 20 295 a 195 195 0 0 1 195 -95"
      fill="none"
      stroke="none"
    />

    <!-- 6m area left — simplified arc -->
    <path
      d="M 20 118 Q 165 118 200 200 Q 165 282 20 282"
      fill="rgba(0,0,0,0.18)"
      stroke="white"
      stroke-width="2.5"
      fill-rule="evenodd"
    />

    <!-- 9m line left (dashed) -->
    <path
      d="M 20 68 Q 250 68 300 200 Q 250 332 20 332"
      fill="none"
      stroke="white"
      stroke-width="2"
      stroke-dasharray="8 6"
    />

    <!-- 7m penalty mark left -->
    <line x1="136" y1="196" x2="136" y2="204" stroke="white" stroke-width="3" />

    <!-- RIGHT SIDE: 6m area -->
    <path
      d="M 780 118 Q 635 118 600 200 Q 635 282 780 282"
      fill="rgba(0,0,0,0.18)"
      stroke="white"
      stroke-width="2.5"
    />

    <!-- 9m line right (dashed) -->
    <path
      d="M 780 68 Q 550 68 500 200 Q 550 332 780 332"
      fill="none"
      stroke="white"
      stroke-width="2"
      stroke-dasharray="8 6"
    />

    <!-- 7m penalty mark right -->
    <line x1="664" y1="196" x2="664" y2="204" stroke="white" stroke-width="3" />

    <!-- LEFT GOAL -->
    <rect x="0" y="163" width="20" height="74" fill="#1a1f1d" stroke="white" stroke-width="2" />
    <!-- Goal net (diagonal lines) -->
    <line x1="0" y1="163" x2="20" y2="237" stroke="rgba(255,255,255,0.4)" stroke-width="1" stroke-dasharray="4 4" />
    <line x1="0" y1="180" x2="20" y2="237" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="4 4" />
    <line x1="0" y1="197" x2="20" y2="237" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="4 4" />
    <line x1="0" y1="214" x2="20" y2="237" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="4 4" />
    <line x1="0" y1="231" x2="20" y2="237" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-dasharray="4 4" />

    <!-- RIGHT GOAL -->
    <rect x="780" y="163" width="20" height="74" fill="#1a1f1d" stroke="white" stroke-width="2" />
    <line x1="780" y1="163" x2="800" y2="237" stroke="rgba(255,255,255,0.4)" stroke-width="1" stroke-dasharray="4 4" />
    <line x1="780" y1="180" x2="800" y2="237" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="4 4" />
    <line x1="780" y1="197" x2="800" y2="237" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="4 4" />
    <line x1="780" y1="214" x2="800" y2="237" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="4 4" />
    <line x1="780" y1="231" x2="800" y2="237" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-dasharray="4 4" />

    <!-- Callout: center -->
    <rect x="310" y="14" width="180" height="28" rx="3" fill="rgba(13,17,16,0.85)" stroke="#4ab8e0" stroke-width="1.2" />
    <text x="400" y="32" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="10" fill="#6fd1f5" font-weight="700">Línia central · 40m × 20m</text>

    <!-- Callout: 6m area left -->
    <rect x="30" y="295" width="90" height="28" rx="3" fill="rgba(13,17,16,0.85)" stroke="#4ab8e0" stroke-width="1.2" />
    <text x="75" y="313" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="10" fill="#6fd1f5" font-weight="700">Àrea 6m</text>

    <!-- Callout: 9m right -->
    <rect x="670" y="295" width="100" height="28" rx="3" fill="rgba(13,17,16,0.85)" stroke="#4ab8e0" stroke-width="1.2" />
    <text x="720" y="313" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="10" fill="#6fd1f5" font-weight="700">Línia 9m</text>
  </svg>
</div>

<style>
  .court-wrapper {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    border: 2px solid rgba(74, 184, 224, 0.2);
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.5);
    border-radius: 2px;
    overflow: hidden;
  }

  .court-svg {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
