---
interface Props {
  date: string;
  titol: string;
  location: string;
  image?: string;
}
const { date, titol, location, image } = Astro.props;
---

<div class="event-card reveal">
  {image && (
    <div class="event-img-wrap">
      <img src={image} alt={titol} loading="lazy" class="event-img" />
    </div>
  )}
  <div class="event-body">
    <span class="event-date exp-mono">{date}</span>
    <h3 class="event-titol exp-display">{titol}</h3>
    <p class="event-location exp-accent">{location}</p>
  </div>
</div>

<style>
  .event-card {
    background: linear-gradient(
      135deg,
      rgba(163, 8, 16, 0.18) 0%,
      rgba(26, 31, 29, 0.95) 40%,
      rgba(37, 42, 40, 0.95) 70%,
      rgba(74, 184, 224, 0.12) 100%
    );
    border: 1px solid rgba(74, 184, 224, 0.15);
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .event-card:hover {
    transform: translateY(-4px);
    border-color: var(--chalk-blue);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4), 0 0 20px rgba(74, 184, 224, 0.1);
  }

  .event-img-wrap {
    overflow: hidden;
    height: 180px;
  }

  .event-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    filter: brightness(0.75) saturate(0.8);
  }

  .event-card:hover .event-img {
    transform: scale(1.05);
    filter: brightness(0.9) saturate(1);
  }

  .event-body {
    padding: 1.5rem;
  }

  .event-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--chalk-blue);
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .event-titol {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    line-height: 1.1;
    color: var(--chalk);
    margin-bottom: 0.5rem;
  }

  .event-location {
    font-family: 'Caveat', cursive;
    font-size: 1.05rem;
    color: var(--chalk-dim);
  }
</style>
