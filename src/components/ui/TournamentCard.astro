---
interface Props {
  name: string;
  category: string;
  slug: string;
}

const { name, category, slug } = Astro.props;
---

<div class="bg-white rounded-sm p-8 text-center shadow-md hover:shadow-xl transition-shadow duration-300" data-aos="fade-up">
  <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#D10A11" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
  </div>
  <span class="text-primary text-xs font-bold uppercase tracking-wider">{category}</span>
  <h3 class="font-heading font-bold text-xl text-dark mt-2 mb-4">{name}</h3>
  <a href={`/equips/${slug}`} class="text-primary hover:text-primary-dark font-heading font-bold text-sm uppercase tracking-wider transition-colors">
    Veure detall →
  </a>
</div>
