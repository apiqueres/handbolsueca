---
import { siteConfig } from '../../data/site';
import Button from '../ui/Button.astro';
import { withBase } from '../../utils/url';
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0">
    <img
      src={withBase('/presentacion-todosequiposjuntos.jpeg')}
      alt="Presentació de tots els equips del Club Handbol Sueca"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-dark/80 via-dark/60 to-dark/40"></div>
  </div>

  <div class="container-custom relative z-10 text-center">
    <h1
      class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-heading font-extrabold text-white mb-4 tracking-tight"
      data-aos="fade-up"
    >
      CLUB HANDBOL<br>
      <span class="text-primary-light">SUECA</span>
    </h1>
    <p
      class="text-lg md:text-xl text-white/80 mb-8 max-w-2xl mx-auto"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      Passió pel handbol des de {siteConfig.founded}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-aos="fade-up" data-aos-delay="200">
      <Button href={withBase('/club/qui-som')} variant="primary">Coneix-nos</Button>
      <Button href={withBase('/equips')} variant="outline">Els nostres equips</Button>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60"><path d="m6 9 6 6 6-6"/></svg>
  </div>
</section>
