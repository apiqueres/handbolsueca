---
import { teams } from '../../data/teams';
import TeamCard from '../ui/TeamCard.astro';
import { withBase } from '../../utils/url';
---

<section class="section-padding bg-primary">
  <div class="container-custom">
    <div class="text-center mb-12" data-aos="fade-up">
      <span class="text-white/70 font-heading font-bold text-sm uppercase tracking-wider">Categoria per categoria</span>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-white mt-2">
        Els Nostres Equips
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {teams.map((team) => (
        <TeamCard
          slug={team.slug}
          name={team.name}
          category={team.category}
          coach={team.coach}
          image={team.image}
        />
      ))}
    </div>

    <div class="text-center mt-10" data-aos="fade-up">
      <a href={withBase('/equips')} class="btn-outline">Veure tots els equips</a>
    </div>
  </div>
</section>
