---
import { events } from '../../data/events';
import EventCard from '../ui/EventCard.astro';
import { withBase } from '../../utils/url';
---

<section class="section-padding bg-gray-soft">
  <div class="container-custom">
    <div class="text-center mb-12" data-aos="fade-up">
      <span class="text-primary font-heading font-bold text-sm uppercase tracking-wider">Agenda</span>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-dark mt-2">
        Events Propers
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {events.slice(0, 3).map((event) => (
        <EventCard
          slug={event.slug}
          name={event.name}
          date={event.date}
          location={event.location}
          image={event.image}
          category={event.category}
        />
      ))}
    </div>

    <div class="text-center mt-10" data-aos="fade-up">
      <a href={withBase('/events')} class="btn-outline-dark">Veure tots els events</a>
    </div>
  </div>
</section>
